{
  "$schema": "./forge.schema.json",
  "doctor": {
    "auto_fix": true,
    "backup_dir": ".forge/backup"
  },
  "max_requests_per_turn": 100,
  "max_tokens": 20480,
  "max_tool_failure_per_turn": 3,
  "max_walker_depth": 1,
  "model": "anthropic/claude-sonnet-4",
  "provider": {
    "default": "anthropic",
    "anthropic": {},
    "openai": {}
  },
  "system": {
    "compact": {
      "enabled": true,
      "max_tokens": 2000,
      "token_threshold": 100000,
      "retention_window": 6,
      "message_threshold": 200,
      "eviction_window": 0.2
    }
  },
  "tool_supported": true,
  "top_k": 30,
  "top_p": 0.8,
  "updates": {
    "frequency": "daily",
    "auto_update": false
  },
  "variables": {
    "operating_agent": "Forge",
    "advanced_model": "anthropic/claude-sonnet-4"
  }
}
